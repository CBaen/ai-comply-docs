# Stripe — restricted key with Checkout Sessions read+write
STRIPE_SECRET_KEY=rk_live_...

# Stripe webhook signing secret — REQUIRED for payment verification
# Without this, the webhook endpoint returns 500 and Stripe retries flood your logs
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — for sending compliance documents via email
RESEND_API_KEY=re_...

# Auth.js session signing secret — REQUIRED in production
# Without this, sessions use an unpredictable secret that changes on each cold start
AUTH_SECRET=generate-a-random-string-here

# Neon PostgreSQL — REQUIRED for purchase records and auth persistence
# Without this, purchases aren't recorded and auth falls back to stateless JWT
DATABASE_URL=postgresql://...

# Google Analytics 4 — optional, for server-side purchase tracking
# Both must be set for GA4 Measurement Protocol to work
GA_MEASUREMENT_ID=G-...
GA_API_SECRET=...

# Upstash Redis — optional, for global rate limiting across Vercel instances
# Without this, rate limiting falls back to per-instance in-memory (bypassable under load)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
